# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Replace with your local MongoDB URI or MongoDB Atlas URI
MONGO_URI=mongodb://localhost:27017/farm_fresh

# Security Configuration
JWT_SECRET=super_secret_jwt_passkey_change_in_production
JWT_EXPIRE=30d

# CORS Configuration
# Development: Use * or leave empty
# Production: Set to your frontend URL (e.g., https://your-app.vercel.app)
CORS_ORIGIN=*
